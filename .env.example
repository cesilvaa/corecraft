# Credenciais compartilhadas do Bitcoin Core.
#
# Definidas aqui uma única vez e injetadas automaticamente pelo docker-compose em:
#   - bitcoin-regtest e bitcoin-signet (via env_file)
#   - corecraft-v* (via environment, sobrescrevendo o que vier do env da atividade)
#
# Copie para .env e preencha com os valores reais:
#   cp .env.example .env

BITCOIN_RPC_USER=your_rpc_user
BITCOIN_RPC_PASSWORD=your_rpc_password
