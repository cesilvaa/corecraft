# Template de variáveis de ambiente para o ambiente sandbox (signet / node2).
#
# Para usar:
#   cp .env.sandbox.example .env.sandbox
#   # preencha as credenciais reais
#   RAILS_ENV=sandbox docker compose up

# Bitcoin RPC — sandbox (node2, porta 18463)
BITCOIN_RPC_HOST=ubuntu
BITCOIN_RPC_PORT=18473
BITCOIN_RPC_USER=corecraft
BITCOIN_RPC_PASSWORD=your_password_here
BITCOIN_RPC_NETWORK=signet

# Bitcoin ZMQ — sandbox (node2/signet, porta 28335)
BITCOIN_ZMQ_HOST=ubuntu
BITCOIN_ZMQ_PORT=28335
BITCOIN_ZMQ_ENABLED=true
