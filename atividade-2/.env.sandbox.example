# Template de variáveis de ambiente para o ambiente sandbox (signet).
#
# Para usar:
#   cp .env.sandbox.example .env.sandbox
#   RAILS_ENV=sandbox docker compose up corecraft-v2

# Bitcoin RPC — sandbox (signet)
BITCOIN_RPC_HOST=bitcoin-signet
BITCOIN_RPC_PORT=18473
BITCOIN_RPC_NETWORK=signet

# Bitcoin ZMQ — sandbox (signet)
BITCOIN_ZMQ_HOST=bitcoin-signet
BITCOIN_ZMQ_PORT=28335
BITCOIN_ZMQ_ENABLED=true
