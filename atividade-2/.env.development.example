# Variáveis de ambiente para development (regtest).
# Copie para .env.development e preencha com as credenciais reais.
#
#   cp .env.development.example .env.development

# Bitcoin RPC — regtest
BITCOIN_RPC_HOST=bitcoin-regtest
BITCOIN_RPC_PORT=18443
BITCOIN_RPC_USER=your_rpc_user
BITCOIN_RPC_PASSWORD=your_rpc_password
BITCOIN_RPC_NETWORK=regtest

# Bitcoin ZMQ — regtest
BITCOIN_ZMQ_HOST=bitcoin-regtest
BITCOIN_ZMQ_PORT=28332
BITCOIN_ZMQ_ENABLED=true
