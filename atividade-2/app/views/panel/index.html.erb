<% content_for :title, "CoreCraft Panel" %>
<% content_for :head do %>
  <%= stylesheet_link_tag "panel" %>
<% end %>

<div class="panel-wrapper">
  <header class="panel-header">
    <div class="panel-header__logo">
      <span class="panel-header__icon">₿</span>
      <span class="panel-header__title">CoreCraft</span>
    </div>
    <span class="panel-header__subtitle">Node Dashboard</span>
  </header>

  <% if @node_error %>
    <div class="alert alert--error">
      Bitcoin node unavailable. Check your RPC connection.
    </div>
  <% else %>

    <%# ── Divergence banner ── %>
    <% divergence = @state_comparison&.dig(:divergence) %>
    <div class="divergence-banner <%= divergence ? 'divergence-banner--alert' : 'divergence-banner--ok' %>">
      <span class="divergence-banner__icon"><%= divergence ? '⚠' : '✓' %></span>
      <div class="divergence-banner__content">
        <span class="divergence-banner__title">
          <%= divergence ? 'Block divergence detected' : 'ZMQ and RPC in sync' %>
        </span>
        <div class="divergence-banner__hashes">
          <span class="divergence-banner__hash-label">RPC best block:</span>
          <code class="divergence-banner__hash"><%= @state_comparison&.dig(:best_block) || '—' %></code>
          <span class="divergence-banner__hash-label">Last ZMQ block:</span>
          <code class="divergence-banner__hash"><%= @state_comparison&.dig(:last_seen_block) || 'none yet' %></code>
        </div>
      </div>
    </div>

    <main class="panel-grid">

      <%# ── Mempool Intelligence ── %>
      <section class="card">
        <div class="card__header">
          <span class="card__icon">⛓</span>
          <h2 class="card__title">Mempool Intelligence</h2>
        </div>
        <div class="card__body">
          <div class="stat">
            <span class="stat__label">Total Transactions</span>
            <span class="stat__value"><%= @mempool[:tx_count] %></span>
          </div>
          <div class="stat">
            <span class="stat__label">Avg Fee Rate</span>
            <span class="stat__value"><%= @mempool[:avg_fee_rate] %> <span class="stat__unit">sat/vB</span></span>
          </div>
          <div class="divider"></div>
          <h3 class="card__section-title">Fee Distribution</h3>
          <div class="fee-distribution">
            <div class="fee-bar">
              <span class="fee-bar__label fee-bar__label--low">Low</span>
              <span class="fee-bar__value"><%= @mempool[:fee_distribution][:low] %></span>
            </div>
            <div class="fee-bar">
              <span class="fee-bar__label fee-bar__label--medium">Medium</span>
              <span class="fee-bar__value"><%= @mempool[:fee_distribution][:medium] %></span>
            </div>
            <div class="fee-bar">
              <span class="fee-bar__label fee-bar__label--high">High</span>
              <span class="fee-bar__value"><%= @mempool[:fee_distribution][:high] %></span>
            </div>
          </div>
        </div>
      </section>

      <%# ── Node Sync Status ── %>
      <section class="card">
        <div class="card__header">
          <span class="card__icon">📡</span>
          <h2 class="card__title">Node Sync Status</h2>
        </div>
        <div class="card__body">
          <div class="stat">
            <span class="stat__label">Blocks Downloaded</span>
            <span class="stat__value"><%= number_with_delimiter(@sync[:blocks]) %></span>
          </div>
          <div class="stat">
            <span class="stat__label">Total Headers</span>
            <span class="stat__value"><%= number_with_delimiter(@sync[:headers]) %></span>
          </div>
          <div class="divider"></div>
          <div class="stat stat--highlight <%= @sync[:lag].zero? ? 'stat--synced' : 'stat--lagging' %>">
            <span class="stat__label">Lag</span>
            <span class="stat__value">
              <%= @sync[:lag].zero? ? "Fully synced ✓" : "#{number_with_delimiter(@sync[:lag])} blocks behind" %>
            </span>
          </div>
        </div>
      </section>

      <%# ── Event Activity ── %>
      <section class="card">
        <div class="card__header">
          <span class="card__icon">⚡</span>
          <h2 class="card__title">Event Activity</h2>
        </div>
        <div class="card__body">
          <div class="stat">
            <span class="stat__label">Transactions Received</span>
            <span class="stat__value"><%= @event_summary[:tx_observed] %></span>
          </div>
          <div class="stat">
            <span class="stat__label">Blocks Received</span>
            <span class="stat__value"><%= @event_summary[:blocks_observed] %></span>
          </div>
          <div class="stat">
            <span class="stat__label">Tx Rate</span>
            <span class="stat__value"><%= @event_summary[:tx_per_second] %> <span class="stat__unit">tx/s</span></span>
          </div>
          <div class="divider"></div>
          <div class="stat">
            <span class="stat__label">Last Event</span>
            <span class="stat__value stat__value--mono">
              <% if @event_summary[:last_event_time] %>
                <%= Time.at(@event_summary[:last_event_time]).utc.strftime("%H:%M:%S UTC") %>
              <% else %>
                <span class="stat__value--muted">no events yet</span>
              <% end %>
            </span>
          </div>
        </div>
      </section>

      <%# ── Últimos Eventos ── %>
      <section class="card card--wide">
        <div class="card__header">
          <span class="card__icon">🔍</span>
          <h2 class="card__title">Últimos Eventos</h2>
        </div>
        <div class="card__body card__body--split">

          <div class="event-column">
            <h3 class="card__section-title">Últimos Blocos</h3>
            <% if @event_latest[:blocks].empty? %>
              <p class="event-empty">No blocks observed yet</p>
            <% else %>
              <ul class="event-list">
                <% @event_latest[:blocks].reverse.each do |blk| %>
                  <li class="event-item">
                    <code class="event-item__hash"><%= blk[:hash] %></code>
                    <span class="event-item__time"><%= Time.at(blk[:ts]).utc.strftime("%H:%M:%S") %></span>
                  </li>
                <% end %>
              </ul>
            <% end %>
          </div>

          <div class="event-column">
            <h3 class="card__section-title">Últimas Transações</h3>
            <% if @event_latest[:txs].empty? %>
              <p class="event-empty">No transactions observed yet</p>
            <% else %>
              <ul class="event-list">
                <% @event_latest[:txs].reverse.each do |tx| %>
                  <li class="event-item">
                    <code class="event-item__hash"><%= tx[:txid] %></code>
                    <span class="event-item__time"><%= Time.at(tx[:ts]).utc.strftime("%H:%M:%S") %></span>
                  </li>
                <% end %>
              </ul>
            <% end %>
          </div>

        </div>
      </section>

    </main>
  <% end %>
</div>
