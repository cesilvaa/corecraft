# Variáveis de ambiente para sandbox (signet).
# Copie para .env.sandbox e preencha com as credenciais reais.
#
#   cp .env.sandbox.example .env.sandbox

# Bitcoin RPC — signet
BITCOIN_RPC_HOST=bitcoin-signet
BITCOIN_RPC_PORT=18473
BITCOIN_RPC_USER=your_rpc_user
BITCOIN_RPC_PASSWORD=your_rpc_password
BITCOIN_RPC_NETWORK=signet
