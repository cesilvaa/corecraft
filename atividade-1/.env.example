# Template de variáveis de ambiente para o ambiente development (regtest).
#
# Convenção de nomes:
#   .env.development  → carregado quando RAILS_ENV=development (padrão)
#   .env.sandbox      → carregado quando RAILS_ENV=sandbox
#
# Para usar:
#   cp .env.example .env.development
#   docker compose up corecraft-v1
#
# Para sandbox:
#   cp .env.sandbox.example .env.sandbox
#   RAILS_ENV=sandbox docker compose up corecraft-v1

# Bitcoin RPC — development (regtest)
BITCOIN_RPC_HOST=bitcoin-regtest
BITCOIN_RPC_PORT=18443
BITCOIN_RPC_NETWORK=regtest
